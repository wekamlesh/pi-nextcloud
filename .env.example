# Persistent paths on the SSD
POSTGRES_DATA_DIR=/mnt/ssd/postgres
REDIS_DATA_DIR=/mnt/ssd/redis
NEXTCLOUD_APP_DIR=/mnt/ssd/nextcloud/app
NEXTCLOUD_DATA_DIR=/mnt/ssd/nextcloud/data
BACKUP_ROOT=/mnt/ssd/backups

# PostgreSQL
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# Nextcloud admin bootstrap
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
NEXTCLOUD_TRUSTED_DOMAINS=cloud.example.com
NEXTCLOUD_OVERWRITE_CLI_URL=https://cloud.example.com
TRUSTED_PROXIES=172.16.0.0/12
DEFAULT_PHONE_REGION=IN

# PHP / Apache upload tuning
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=512M
APACHE_BODY_LIMIT=1073741824

# Cloudflare Tunnel
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_your_tunnel_token

# Backups
BACKUP_RETENTION_DAYS=14
